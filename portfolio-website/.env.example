# EmailJS Configuration
# Get these values from https://www.emailjs.com/
# 1. Sign up for a free EmailJS account
# 2. Add your email service (Gmail recommended): vishwa29patel.cg@gmail.com
# 3. Create an email template with variables: {{from_name}}, {{from_email}}, {{message}}
# 4. Copy your Service ID, Template ID, and Public Key here

REACT_APP_EMAILJS_SERVICE_ID=your_service_id_here
REACT_APP_EMAILJS_TEMPLATE_ID=your_template_id_here
REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key_here

# Example:
# REACT_APP_EMAILJS_SERVICE_ID=service_portfolio
# REACT_APP_EMAILJS_TEMPLATE_ID=template_contact
# REACT_APP_EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY_HERE

# IMPORTANT: All form submissions will be sent to: vishwa29patel.cg@gmail.com
# After setting up, rename this file to .env (it should already be ignored by git)
